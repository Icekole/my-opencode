        },
        "glm-5": {
          "name": "glm-5"
        },
        "kimi-k2.5": {
          "name": "kimi-k2.5"
        },
        "MiniMax-M2.5": {
          "name": "MiniMax-M2.5"
        }
      }
    }
  }
}
